# no .a files
*.a
*.bin
*.dll
*.def
*.exp
*.lib
*.obj


# but do track lib.a, even though you're ignoring .a files above
#!lib.a
lib

loader.sce
unloader.sce
cleaner.sce
cleaner_gateway.sce
cleaner_src.sce
Makelib.mak
gw_ipcv*
libgw*

# only ignore the TODO file in the current directory, not subdir/TODO
#/TODO

# ignore all files in the build/ directory
Release/
jar/
2.0/
**/testing
tests/results/

# Local Codex/Scilab test profile and separately versioned website workspace.
.codex/
/website/

# ignore bundled thirdparty payloads, but keep build helper scripts tracked
thirdparty/*
!thirdparty/build/
thirdparty/build/*
!thirdparty/build/README.txt
!thirdparty/build/build.bat
!thirdparty/build/build.sh

# generated help output
help/en_US/scilab_en_US_help/

# DNN models are downloaded on demand by demos/tests.
*.onnx
*.caffemodel

# OpenCV Zoo GUI generated starter scripts in the default DNN download folder.
images/dnn/*_sample.sce

# DNN demo downloads.
images/dnn/dog416.png
images/dnn/fruits.jpg
images/dnn/lena.jpg
images/dnn/messi5.jpg
images/dnn/object_detection_classes_coco.txt
images/dnn/object_detection_classes_yolo.txt
images/dnn/deploy.prototxt
images/dnn/opencv_face_detector_uint8.pb
images/dnn/opencv_face_detector.pbtxt
images/dnn/human_segmentation_pphumanseg_README.md

# ignore doc/notes.txt, but not doc/server/arch.txt
#doc/*.txt

# ignore all .pdf files in the doc/ directory
#doc/**/*.pdf
