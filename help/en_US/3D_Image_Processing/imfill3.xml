<refentry version="5.0-subset Scilab" xml:id="imfill3" xml:lang="en" xmlns="http://docbook.org/ns/docbook">
<refnamediv><refname>imfill3</refname><refpurpose>Fill enclosed cavities in a 3-D binary volume.</refpurpose></refnamediv>
<refsynopsisdiv><title>Syntax</title><synopsis>out = imfill3(volume)
out = imfill3(volume, connectivity)</synopsis></refsynopsisdiv>
<refsection><title>Parameters</title><variablelist>
<varlistentry><term>volume</term><listitem><para>Binary or numeric 3-D volume.</para></listitem></varlistentry>
<varlistentry><term>connectivity</term><listitem><para>Background connectivity: <literal>6</literal>, <literal>18</literal>, or <literal>26</literal>. Default is 6.</para></listitem></varlistentry>
<varlistentry><term>out</term><listitem><para>Boolean volume with enclosed background cavities filled.</para></listitem></varlistentry>
</variablelist></refsection>
<refsection><title>Description</title><para>Floods background from all six volume faces and fills background components that cannot reach the border.</para></refsection>
<refsection><title>Examples</title><programlisting><![CDATA[
volume = zeros(31, 31, 17) == 1;
volume(6:26, 6:26, 4:14) = %t;
volume(11:21, 11:21, 7:11) = %f;
filled = imfill3(volume, 6);
subplot(1, 2, 1);
imshow(volume(:, :, 9));
subplot(1, 2, 2);
imshow(filled(:, :, 9));
]]></programlisting></refsection>
