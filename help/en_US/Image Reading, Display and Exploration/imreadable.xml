  <refnamediv>
    <refname>imreadable</refname>
    <refpurpose>Check whether OpenCV can read an image file</refpurpose>
  </refnamediv>

<refsynopsisdiv>
   <title>Syntax</title>
   <synopsis>
   supported = imreadable(filename)
   </synopsis>
</refsynopsisdiv>

<refsection>
   <title>Parameters</title>
   <variablelist>
        <varlistentry>
            <term>filename :</term>
            <listitem><para> A string, the image filename to check.</para></listitem>
        </varlistentry>
        <varlistentry>
            <term>supported :</term>
            <listitem><para> Boolean value. %t means OpenCV has a reader for the file and can open it.</para></listitem>
        </varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
imreadable checks OpenCV image reader support without decoding the full image.
   </para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
filename = fullpath(getIPCVpath() + "/images/" + "baboon.png");
imreadable(filename)
   ]]></programlisting>
</refsection>

