          xmlns:db="http://docbook.org/ns/docbook">

  <refnamediv>
    <refname>imcount</refname>
    <refpurpose>Count pages or frames in an image file</refpurpose>
  </refnamediv>

<refsynopsisdiv>
   <title>Syntax</title>
   <synopsis>
   count = imcount(filename)
   </synopsis>
</refsynopsisdiv>

<refsection>
   <title>Parameters</title>
   <variablelist>
        <varlistentry>
            <term>filename :</term>
            <listitem><para> A string, the image filename to inspect.</para></listitem>
        </varlistentry>
        <varlistentry>
            <term>count :</term>
            <listitem><para> Number of pages or frames in the image file. Single-page images return 1.</para></listitem>
        </varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
imcount returns the page or frame count reported by OpenCV. It is useful before calling imreadmulti on TIFF and other multi-page formats.
   </para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
filename = fullpath(getIPCVpath() + "/images/" + "img_multipage.tiff");
count = imcount(filename);
   ]]></programlisting>
</refsection>

