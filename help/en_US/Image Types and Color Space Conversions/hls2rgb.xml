  <refnamediv>
    <refname>hls2rgb</refname>
    <refpurpose>Convert an HLS image to RGB.</refpurpose>
  </refnamediv>


<refsynopsisdiv>
   <title>Syntax</title>
   <synopsis>
   rgb = hls2rgb(hls)

   </synopsis>
</refsynopsisdiv>

<refsection role="arguments">
   <title>Arguments</title>
   <variablelist>
        <varlistentry>
            <term>hls :</term>
            <listitem><para> HLS image.</para></listitem>
        </varlistentry>
        <varlistentry>
            <term>rgb :</term>
            <listitem><para> RGB image.</para></listitem>
        </varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
hls2rgb converts an HLS image to RGB using OpenCV 5 cvtColor.
   </para>
   <para>
</para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
rgb = imread(fullpath(getIPCVpath() + "/images/" + "baboon.png"));
hls = rgb2hls(rgb);
rgb2 = hls2rgb(hls);

   ]]></programlisting>
</refsection>

