  <refnamediv>
    <refname>rgb2luv</refname>
    <refpurpose>Convert an RGB image to Luv.</refpurpose>
  </refnamediv>


<refsynopsisdiv>
   <title>Syntax</title>
   <synopsis>
   luv = rgb2luv(rgb)

   </synopsis>
</refsynopsisdiv>

<refsection role="arguments">
   <title>Arguments</title>
   <variablelist>
        <varlistentry>
            <term>rgb :</term>
            <listitem><para> RGB image.</para></listitem>
        </varlistentry>
        <varlistentry>
            <term>luv :</term>
            <listitem><para> Luv image.</para></listitem>
        </varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
rgb2luv converts an RGB image to CIE Luv using OpenCV 5 cvtColor.
   </para>
   <para>
</para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
rgb = imread(fullpath(getIPCVpath() + "/images/" + "baboon.png"));
luv = rgb2luv(rgb);

   ]]></programlisting>
</refsection>

