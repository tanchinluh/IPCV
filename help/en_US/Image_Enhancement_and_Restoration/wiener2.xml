<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="wiener2" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>wiener2</refname><refpurpose>Apply a local Wiener filter.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>out = wiener2(image); out = wiener2(image, window, noise)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>Input image.</para></listitem></varlistentry><varlistentry><term>window</term><listitem><para>[rows cols] local window. Default is [3 3].</para></listitem></varlistentry><varlistentry><term>noise</term><listitem><para>Optional noise power estimate.</para></listitem></varlistentry></variablelist></refsection><refsection><title>Description</title><para><function>wiener2</function> is a MATLAB-style compatibility entry point for <function>imwiener2</function>.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[image = imread(fullpath(getIPCVpath() + "/images/coins_gray.jpg")); out = wiener2(image, [3 3]); imshow(out);]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="imwiener2">imwiener2</link></member><member><link linkend="immedianfilt">immedianfilt</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Compatibility entry point introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
