<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="immedianfilt" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>immedianfilt</refname><refpurpose>Apply median filtering.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>out = immedianfilt(image); out = immedianfilt(image, ksize)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>Input image.</para></listitem></varlistentry><varlistentry><term>ksize</term><listitem><para>Positive odd scalar window size. Default is 3.</para></listitem></varlistentry></variablelist></refsection><refsection><title>Description</title><para><function>immedianfilt</function> is a MATLAB-style compatibility entry point for <function>immedian</function>.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[image = imread(fullpath(getIPCVpath() + "/images/coins_gray.jpg")); out = immedianfilt(image, 3); imshow(out);]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="immedian">immedian</link></member><member><link linkend="immedianfilt">immedianfilt</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Compatibility entry point introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
