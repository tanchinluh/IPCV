<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="im2uint32" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>im2uint32</refname><refpurpose>Convert an image to unsigned 32-bit intensity values.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>out = im2uint32(image)</synopsis></refsynopsisdiv><refsection><title>Description</title><para>Converts normalized image data to the full unsigned 32-bit range with clipping at zero and one.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[image = imread(fullpath(getIPCVpath() + "/images/opencv_smarties.png"));
wideImage = im2uint32(image);
imshow(im2uint8(wideImage));]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="im2uint16">im2uint16</link></member><member><link linkend="im2double">im2double</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Function introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
