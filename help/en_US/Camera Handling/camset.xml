<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="camset" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>camset</refname><refpurpose>Set a property on an opened camera.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>ok = camset(handle, prop, value)</synopsis></refsynopsisdiv><refsection><title>Description</title><para><function>camset</function> sets OpenCV camera capture properties by numeric id or by name. Hardware and backend support varies by camera.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[n = camopen(0);
ok = camset(n, "fps", 30);
camclose(n);
]]></programlisting></refsection><refsection><title>See Also</title><simplelist type="inline"><member>camget</member><member>camprops</member><member>imvideopropid</member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td><emphasis role="bold">Version</emphasis></td><td><emphasis role="bold">Description</emphasis></td></tr><tr><td>5.0.0</td><td>Function introduced.</td></tr></informaltable></refsection></refentry>
