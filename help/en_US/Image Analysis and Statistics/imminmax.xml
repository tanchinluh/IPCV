  <refnamediv>
    <refname>imminmax</refname>
    <refpurpose>Compute per-channel image minimum and maximum values.</refpurpose>
  </refnamediv>

<refsynopsisdiv>
   <title>Syntax</title>
   <synopsis>
   [minValue, maxValue] = imminmax(im)
   </synopsis>
</refsynopsisdiv>

<refsection role="arguments">
   <title>Arguments</title>
   <variablelist>
        <varlistentry><term>im :</term><listitem><para>Input image.</para></listitem></varlistentry>
        <varlistentry><term>minValue :</term><listitem><para>Row vector of per-channel minimum values.</para></listitem></varlistentry>
        <varlistentry><term>maxValue :</term><listitem><para>Row vector of per-channel maximum values.</para></listitem></varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
      <function>imminmax</function> reports minimum and maximum values for each image channel.
   </para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
im = imread(fullpath(getIPCVpath() + "/images/" + "baboon.png"));
[lo, hi] = imminmax(im);
   ]]></programlisting>
</refsection>

