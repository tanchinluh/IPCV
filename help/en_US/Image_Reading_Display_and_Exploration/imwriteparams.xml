<refnamediv><refname>imwriteparams</refname><refpurpose>Return common image write option values.</refpurpose></refnamediv>
<refsynopsisdiv><title>Syntax</title><synopsis>params = imwriteparams()</synopsis></refsynopsisdiv>
<refsection><title>Description</title><para><function>imwriteparams</function> describes JPEG quality and PNG compression values accepted by <function>imwrite</function>.</para></refsection>
<refsection><title>Examples</title><programlisting role="example"><![CDATA[
params = imwriteparams();
disp(params.png_compression_max);
]]></programlisting></refsection>
