<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="aviseek" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>aviseek</refname><refpurpose>Seek an opened video capture to a one-based frame index.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>ok = aviseek(handle, frameIndex)</synopsis></refsynopsisdiv><refsection><title>Description</title><para><function>aviseek</function> moves the next read position of an opened video capture.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[n = aviopen(fullpath(getIPCVpath() + "/images/video.avi"));
aviseek(n, 10);
im = avireadframe(n);
aviclose(n);
]]></programlisting></refsection><refsection><title>See Also</title><simplelist type="inline"><member>avipos</member><member>avireadframe</member><member>aviset</member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td><emphasis role="bold">Version</emphasis></td><td><emphasis role="bold">Description</emphasis></td></tr><tr><td>5.0.0</td><td>Function introduced.</td></tr></informaltable></refsection></refentry>
