<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="avipos" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>avipos</refname><refpurpose>Return current video capture position.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>[frameIndex, msec, ratio] = avipos(handle)</synopsis></refsynopsisdiv><refsection><title>Description</title><para><function>avipos</function> returns a one-based next frame index, position in milliseconds, and AVI ratio where supported by the backend.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[n = aviopen(fullpath(getIPCVpath() + "/images/video.avi"));
[frameIndex, msec, ratio] = avipos(n);
aviclose(n);
]]></programlisting></refsection><refsection><title>See Also</title><simplelist type="inline"><member>aviseek</member><member>aviget</member><member>avireadframe</member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td><emphasis role="bold">Version</emphasis></td><td><emphasis role="bold">Description</emphasis></td></tr><tr><td>5.0.0</td><td>Function introduced.</td></tr></informaltable></refsection></refentry>
