<refentry version="5.0-subset Scilab" xml:id="imvar" xml:lang="en" xmlns="http://docbook.org/ns/docbook" xmlns:scilab="http://www.scilab.org">
<refnamediv><refname>imvar</refname><refpurpose>Return image sample variance.</refpurpose></refnamediv>
<refsynopsisdiv><title>Syntax</title><synopsis>value = imvar(image)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>Input image or numeric array.</para></listitem></varlistentry><varlistentry><term>value</term><listitem><para>Variance of all image values.</para></listitem></varlistentry></variablelist></refsection>
<refsection><title>Description</title><para><function>imvar</function> computes sample variance over all image values and channels.</para></refsection>
<refsection><title>Examples</title><programlisting><![CDATA[image = imread(fullpath(getIPCVpath() + "/images/opencv_smarties.png"));
image = imresize(rgb2gray(image), [120 160]);
value = imvar(image);
disp(value);
imshow(image);]]></programlisting></refsection>
