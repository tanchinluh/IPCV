<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="imgradientdirection" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>imgradientdirection</refname><refpurpose>Compute Sobel gradient direction.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>direction = imgradientdirection(image)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>Grayscale or RGB image.</para></listitem></varlistentry><varlistentry><term>direction</term><listitem><para>Double direction image in degrees from -180 to 180.</para></listitem></varlistentry></variablelist></refsection><refsection><title>Description</title><para><function>imgradientdirection</function> computes the angle of the Sobel vector using the image row and column coordinate convention.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[
image = imread(fullpath(getIPCVpath() + "/images/opencv_left01.jpg"));
image = imresize(rgb2gray(image), [120 160]);
direction = imgradientdirection(image);
subplot(1, 2, 1);
imshow(image);
subplot(1, 2, 2);
imshow(immat2gray(direction));
]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="imgradientxy">imgradientxy</link></member><member><link linkend="imgradientmagnitude">imgradientmagnitude</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Function introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
