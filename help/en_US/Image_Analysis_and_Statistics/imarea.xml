<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="imarea" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>imarea</refname><refpurpose>Count foreground pixels.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>area = imarea(image)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>A 2D binary or numeric image. Nonzero pixels are foreground.</para></listitem></varlistentry><varlistentry><term>area</term><listitem><para>Scalar foreground pixel count.</para></listitem></varlistentry></variablelist></refsection><refsection><title>Description</title><para><function>imarea</function> counts nonzero pixels.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[mask = zeros(5, 5) == 1; mask(2:4, 2:4) = %t; area = imarea(mask);]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="imconnectedcomponents">imconnectedcomponents</link></member><member><link linkend="bwareaopen">bwareaopen</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Function introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
