<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="imintegral" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>imintegral</refname><refpurpose>Compute a 2D summed-area table.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>out = imintegral(image)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>Input 2-D image.</para></listitem></varlistentry><varlistentry><term>out</term><listitem><para>Integral image with an extra top row and left column of zeros.</para></listitem></varlistentry></variablelist></refsection><refsection><refsection><title>Description</title><para>Returns a double precision integral image with a zero-valued first row and column, suitable for fast rectangular-window sums.</para></refsection></refsection><refsection><title>Examples</title><programlisting><![CDATA[image = rgb2gray(imread(fullpath(getIPCVpath() + "/images/opencv_fruits.jpg")));
table = imintegral(image);
imshow(immat2gray(table(2:$, 2:$)));]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="imlocalmean">imlocalmean</link></member><member><link linkend="immeanstddev">immeanstddev</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Function introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
