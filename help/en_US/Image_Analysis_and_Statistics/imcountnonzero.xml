  <refnamediv>
    <refname>imcountnonzero</refname>
    <refpurpose>Count nonzero pixels per image channel.</refpurpose>
  </refnamediv>

<refsynopsisdiv>
   <title>Syntax</title>
   <synopsis>
   count = imcountnonzero(im)
   </synopsis>
</refsynopsisdiv>

<refsection role="arguments">
   <title>Arguments</title>
   <variablelist>
        <varlistentry><term>im :</term><listitem><para>Input image.</para></listitem></varlistentry>
        <varlistentry><term>count :</term><listitem><para>Row vector of per-channel nonzero counts.</para></listitem></varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
      <function>imcountnonzero</function> counts nonzero pixels in each channel.
   </para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
bw = [%t %f; %t %t];
count = imcountnonzero(bw);
   ]]></programlisting>
</refsection>

