<refentry version="5.0-subset Scilab" xml:id="imlocalentropy" xml:lang="en" xmlns="http://docbook.org/ns/docbook" xmlns:scilab="http://www.scilab.org">
<refnamediv><refname>imlocalentropy</refname><refpurpose>Estimate entropy in local neighborhoods.</refpurpose></refnamediv>
<refsynopsisdiv><title>Syntax</title><synopsis>out = imlocalentropy(image)
out = imlocalentropy(image, window)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>Input image.</para></listitem></varlistentry><varlistentry><term>window</term><listitem><para>Scalar or two-element odd positive local window size. Default is <literal>[9 9]</literal>.</para></listitem></varlistentry><varlistentry><term>out</term><listitem><para>Local Shannon entropy map.</para></listitem></varlistentry></variablelist></refsection>
<refsection><title>Description</title><para>Returns a local Shannon entropy map using 32 quantization levels.</para></refsection>
<refsection><title>Examples</title><programlisting><![CDATA[image = imread(fullpath(getIPCVpath() + "/images/opencv_smarties.png"));
image = imresize(rgb2gray(image), [120 160]);
out = imlocalentropy(image, [9 9]);
subplot(1, 2, 1);
imshow(image);
subplot(1, 2, 2);
outView = round(immat2gray(out) * 63) + 1;
imshow(outView, hot(64));]]></programlisting></refsection>
