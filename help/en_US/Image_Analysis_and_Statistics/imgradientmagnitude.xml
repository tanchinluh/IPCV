<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="imgradientmagnitude" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>imgradientmagnitude</refname><refpurpose>Compute Sobel gradient magnitude.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>magnitude = imgradientmagnitude(image)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>A grayscale or RGB image.</para></listitem></varlistentry><varlistentry><term>magnitude</term><listitem><para>Double-valued Sobel gradient magnitude.</para></listitem></varlistentry></variablelist></refsection><refsection><title>Description</title><para><function>imgradientmagnitude</function> computes the Euclidean magnitude from <function>imgradientxy</function>.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[image = imread(fullpath(getIPCVpath() + "/images/baboon.png")); magnitude = imgradientmagnitude(image); imshow(mat2gray(magnitude));]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="imgradientxy">imgradientxy</link></member><member><link linkend="imgradient">imgradient</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Function introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
