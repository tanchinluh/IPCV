<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="imperimeter" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>imperimeter</refname><refpurpose>Measure the pixel perimeter of a binary image.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>perimeter = imperimeter(image)</synopsis></refsynopsisdiv><refsection><title>Parameters</title><variablelist><varlistentry><term>image</term><listitem><para>A 2D binary or numeric image.</para></listitem></varlistentry><varlistentry><term>perimeter</term><listitem><para>Number of foreground-to-background edges under 4-neighborhoods.</para></listitem></varlistentry></variablelist></refsection><refsection><title>Description</title><para><function>imperimeter</function> returns a grid-based perimeter in pixel-edge units and treats the image border as background.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[
image = imread(fullpath(getIPCVpath() + "/images/opencv_smarties.png"));
image = imresize(rgb2gray(image), [120 160]);
mask = image > 120;
perimeter = imperimeter(mask);
imshow(mask);
disp(perimeter);
]]></programlisting></refsection><refsection role="see also"><title>See also</title><simplelist type="inline"><member><link linkend="bwborder">bwborder</link></member><member><link linkend="imarea">imarea</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td>Version</td><td>Description</td></tr><tr><td>5.0.0</td><td>Function introduced in development Step 3.</td></tr></informaltable></refsection></refentry>
