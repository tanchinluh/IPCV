<refentry version="5.0-subset Scilab" xml:id="imdetect" xml:lang="en" xmlns="http://docbook.org/ns/docbook" xmlns:scilab="http://www.scilab.org">
<refnamediv><refname>imdetect</refname><refpurpose>Detect image features using a named detector.</refpurpose></refnamediv>
<refsynopsisdiv><title>Syntax</title><synopsis>fobj = imdetect(im)
fobj = imdetect(im, method)</synopsis></refsynopsisdiv>
<refsection role="arguments"><title>Arguments</title><variablelist>
<varlistentry><term>im :</term><listitem><para>Input image.</para></listitem></varlistentry>
<varlistentry><term>method :</term><listitem><para>Detector name: <literal>ORB</literal>, <literal>SIFT</literal>, <literal>BRISK</literal>, <literal>FAST</literal>, <literal>GFTT</literal>, <literal>MSER</literal>, <literal>STAR</literal>, or <literal>SURF</literal>. Default is <literal>ORB</literal>.</para></listitem></varlistentry>
<varlistentry><term>fobj :</term><listitem><para>Feature object returned by the selected detector.</para></listitem></varlistentry>
</variablelist></refsection>
<refsection><title>Description</title><para><function>imdetect</function> dispatches to the individual OpenCV 5 feature detector wrappers.</para></refsection>
<refsection><title>Examples</title><programlisting role="example"><![CDATA[
im = imread(fullpath(getIPCVpath() + "/images/" + "balloons_gray.png"));
f = imdetect(im, "ORB");
imshow(im); plotfeature(f);
]]></programlisting></refsection>
