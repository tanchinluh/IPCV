<?xml version="1.0" encoding="UTF-8"?><refentry version="5.0-subset Scilab" xml:id="aviget" xml:lang="en" xmlns="http://docbook.org/ns/docbook"><refnamediv><refname>aviget</refname><refpurpose>Get a property from an opened video capture.</refpurpose></refnamediv><refsynopsisdiv><title>Syntax</title><synopsis>value = aviget(handle, prop)</synopsis></refsynopsisdiv><refsection><title>Description</title><para><function>aviget</function> reads OpenCV video capture properties by numeric id or by name.</para></refsection><refsection><title>Examples</title><programlisting><![CDATA[n = aviopen(fullpath(getIPCVpath() + "/images/video.avi"));
fps = aviget(n, "fps");
frames = aviget(n, "frame_count");
aviclose(n);
]]></programlisting></refsection><refsection><title>See Also</title><simplelist type="inline"><member><link linkend="aviset">aviset</link></member><member><link linkend="avipos">avipos</link></member><member><link linkend="aviseek">aviseek</link></member><member><link linkend="imvideopropid">imvideopropid</link></member></simplelist></refsection><refsection><title>Authors</title><simplelist type="vert"><member>Tan Chin Luh</member></simplelist></refsection><refsection><title>History</title><informaltable border="1"><tr><td><emphasis role="bold">Version</emphasis></td><td><emphasis role="bold">Description</emphasis></td></tr><tr><td>5.0.0</td><td>Function introduced.</td></tr></informaltable></refsection></refentry>
