//==============================================================================
// IPCV OpenCV 5 migration
//==============================================================================
// unit test migrated display utility source layer
//==============================================================================

S = uint8([0 1; 127 128]);
u = mat2utfimg(S);
assert_checkequal(typeof(u), "uint8");
assert_checkequal(u, uint8([1 1 127 194 128]));

RGB = uint8(zeros(1, 1, 3));
RGB(1, 1, 1) = 10;
RGB(1, 1, 2) = 20;
RGB(1, 1, 3) = 130;
u = mat2utfimg(RGB);
assert_checkequal(u, uint8([10 20 194 130]));

